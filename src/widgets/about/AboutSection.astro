---
import { getCollection, render } from 'astro:content';
import { useTranslations } from '../../shared/config/i18n';

/**
 * AboutSection - Renders the "About Me" section with locale-specific content.
 *
 * Fetches content from the 'contents' collection and filters by locale.
 * Falls back through locale hierarchy: es/about → about → any /about entry.
 *
 * @param locale - Language code ('es' | 'en' | 'fr'). Defaults to 'es'.
 * @throws Error if no about content is found for the given locale.
 */
interface Props {
  locale?: string;
}

const { locale = 'es' } = Astro.props;
const t = useTranslations(locale as 'es' | 'en' | 'fr');

/** Fetch all content entries from the 'contents' collection */
const allContents = await getCollection('contents');

/**
 * Resolve the about entry for the current locale.
 * Priority: locale-specific → root fallback → any /about entry.
 */
let about;
if (locale === 'es') {
  about = allContents.find(c => c.id === 'es/about') || allContents.find(c => c.id === 'about');
} else {
  about = allContents.find(c => c.id === `${locale}/about`);
}

if (!about) {
  about = allContents.find(c => c.id.endsWith('/about') || c.id === 'about');
}

if (!about) {
  throw new Error(`Could not find about entry for locale: ${locale}`);
}

/** Render the Markdown content to an Astro component */
const { Content } = await render(about);
---

<section aria-label="about me section of my resume" class="about max-w-[750px] mx-auto" id="about">
	<div class="about-container">
		<h2 class="about-heading">{t.about.title}</h2>
		<div class="about-content">
			<Content />
		</div>
	</div>
</section>

<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		if (typeof gsap !== 'undefined') {
			const tl = gsap.timeline({ defaults: { ease: 'power2.out' } });

			tl.from('.about-heading', { y: 30, opacity: 0, duration: 0.5 })
				.from('.about-content', { y: 30, opacity: 0, duration: 0.5 }, '-=0.3');
		}
	});
</script>

<style>
	.about {
		min-height: 80vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 2rem 1rem;
	}

	.about-container {
		max-width: 750px;
		width: 100%;
		padding: 2rem 0;
	}

	.about-heading {
		font-family: 'Space Grotesk', sans-serif;
		font-size: clamp(2rem, 5vw, 2.5rem);
		font-weight: 700;
		color: #fff;
		margin: 0 0 1.5rem 0;
		line-height: 1.2;
	}

	.about-content {
		font-family: 'Inter', sans-serif;
		font-size: 1.125rem;
		color: #9ca3af;
		line-height: 1.8;
	}

	.about-content :global(p) {
		margin-bottom: 1rem;
	}

	.about-content :global(p:last-child) {
		margin-bottom: 0;
	}
</style>
