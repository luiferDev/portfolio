---
import { languages, languagesFlags, defaultLang, getLangFromUrl } from '../../shared/config/i18n';

interface Props {
  locale?: string;
}

const { locale } = Astro.props;

// Use prop locale if provided, otherwise detect from URL
const currentLang = locale || getLangFromUrl(Astro.url);
const currentPath = Astro.url.pathname;
const currentHash = Astro.url.hash;

// Build language options
const langOptions = Object.entries(languages).map(([lang, label]) => {
  // Build target URL based on current path
  let targetPath: string;
  
  if (currentPath.startsWith('/projects/')) {
    // For project pages, preserve the project slug
    const projectMatch = currentPath.match(/^\/projects\/[^/]+\/(.+)$/);
    if (projectMatch) {
      targetPath = lang === defaultLang ? `/projects/${projectMatch[1]}` : `/projects/${lang}/${projectMatch[1]}`;
    } else {
      targetPath = lang === defaultLang ? '/' : `/${lang}/`;
    }
  } else if (currentPath.startsWith('/contact')) {
    // For contact page
    targetPath = lang === defaultLang ? '/contact' : `/${lang}/contact`;
  } else if (currentPath === '/') {
    // Home page
    targetPath = lang === defaultLang ? '/' : `/${lang}/`;
  } else {
    // Other pages
    targetPath = lang === defaultLang ? '/' : `/${lang}/`;
  }
  
  const targetUrl = `${new URL(targetPath, Astro.site).pathname}${currentHash}`;
  const isCurrent = lang === currentLang;
  
  return { lang, label, targetUrl, isCurrent };
});
---

<!-- Desktop Dropdown Version -->
<div class="lang-switcher-container desktop-lang">
  <button 
    class="lang-switcher-btn" 
    aria-label="Select language"
    aria-expanded="false"
  >
    <span class="current-flag">{languagesFlags[currentLang as keyof typeof languagesFlags]}</span>
    <span class="chevron">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <polyline points="6,9 12,15 18,9"></polyline>
      </svg>
    </span>
  </button>
  
  <div class="lang-dropdown">
    {langOptions.map(opt => (
      <a
        href={opt.targetUrl}
        class={`lang-option ${opt.isCurrent ? 'active' : ''}`}
        data-lang={opt.lang}
        aria-label={`Switch to ${opt.label}`}
      >
        <span class="flag">{languagesFlags[opt.lang as keyof typeof languagesFlags]}</span>
        <span class="label">{opt.label}</span>
      </a>
    ))}
  </div>
</div>

<!-- Mobile Separate Buttons Version - Flags Only -->
<div class="lang-switcher-mobile mobile-lang">
  {langOptions.map(opt => (
    <a
      href={opt.targetUrl}
      class={`lang-btn ${opt.isCurrent ? 'active' : ''}`}
      data-lang={opt.lang}
      aria-label={`Switch to ${opt.label}`}
    >
      <span class="flag">{languagesFlags[opt.lang as keyof typeof languagesFlags]}</span>
    </a>
  ))}
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.querySelector('.desktop-lang');
    const btn = container?.querySelector('.lang-switcher-btn');
    const dropdown = container?.querySelector('.lang-dropdown');
    
    if (btn && dropdown) {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        container?.classList.toggle('open');
        const isOpen = container?.classList.contains('open');
        btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      });
      
      document.addEventListener('click', () => {
        container?.classList.remove('open');
        btn?.setAttribute('aria-expanded', 'false');
      });
      
      dropdown.addEventListener('click', (e) => {
        e.stopPropagation();
      });
    }
  });
</script>

<style>
  /* Desktop Dropdown */
  .desktop-lang {
    position: relative;
    display: inline-block;
  }
  
  .lang-switcher-btn {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 0.75rem;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 0.5rem;
    color: #fff;
    cursor: pointer;
    transition: all 0.25s ease;
    font-family: 'Inter', sans-serif;
  }
  
  .lang-switcher-btn:hover {
    background: rgba(147, 86, 93, 0.3);
    border-color: rgba(147, 86, 93, 0.5);
  }
  
  .current-flag {
    font-size: 1.25rem;
    line-height: 1;
  }
  
  .chevron {
    display: flex;
    align-items: center;
    color: #9ca3af;
    transition: transform 0.25s ease;
  }
  
  .desktop-lang.open .chevron {
    transform: rotate(180deg);
  }
  
  .lang-dropdown {
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    background: rgba(30, 30, 30, 0.95);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 0.75rem;
    padding: 0.5rem;
    min-width: 140px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: all 0.25s ease;
    z-index: 100;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
  }
  
  .desktop-lang.open .lang-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  
  .lang-option {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.625rem 0.75rem;
    border-radius: 0.5rem;
    text-decoration: none;
    color: #d1d5db;
    transition: all 0.2s ease;
  }
  
  .lang-option:hover {
    background: rgba(147, 86, 93, 0.2);
    color: #fff;
  }
  
  .lang-option.active {
    background: rgba(147, 86, 93, 0.3);
    color: #fff;
  }
  
  .lang-option .flag {
    font-size: 1.125rem;
    line-height: 1;
  }
  
  .lang-option .label {
    font-size: 0.875rem;
    font-weight: 500;
  }

  /* Mobile Separate Buttons */
  .mobile-lang {
    display: none;
    gap: 0.375rem;
  }

  .lang-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.375rem 0.5rem;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 0.375rem;
    color: #d1d5db;
    text-decoration: none;
    font-size: 1rem;
    transition: all 0.2s ease;
    min-width: 32px;
    width: 32px;
    height: 32px;
  }
  
  .lang-btn:hover {
    background: rgba(147, 86, 93, 0.2);
    border-color: rgba(147, 86, 93, 0.5);
    color: #fff;
  }
  
  .lang-btn.active {
    background: rgba(147, 86, 93, 0.3);
    border-color: rgba(147, 86, 93, 0.5);
    color: #fff;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .desktop-lang {
      display: none;
    }
    
    .mobile-lang {
      display: flex;
    }
  }
</style>