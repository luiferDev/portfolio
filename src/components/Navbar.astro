---
import { Icon } from 'astro-icon/components';

const leftLinks = [
  { name: 'About', href: '#about' },
  { name: 'Experience', href: '#experience' },
  { name: 'Education', href: '#education' },
];

const rightLinks = [
  { name: 'Projects', href: '#projects' },
  { name: 'Certifications', href: '#certifications' },
  { name: 'Skills', href: '#skills' },
];

const palette = ['#93565d', '#ffffff', '#000000'];
---

<nav class="floating-pill" aria-label="main navigation">
  <div class="pill-left">
    <a href="#about" class="pill-link">About</a>
    <a href="#experience" class="pill-link">Experience</a>
    <a href="#education" class="pill-link">Education</a>
  </div>
  
  <a href="#" class="pill-logo" aria-label="Home">
    <div class="ps5-button">
      <svg class="power-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 2V12M12 12L6 18M12 12L18 18M12 12H4M12 12H20" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"/>
      </svg>
    </div>
  </a>
  
  <div class="pill-right">
    <a href="#projects" class="pill-link">Projects</a>
    <a href="#certifications" class="pill-link">Certifications</a>
    <a href="#skills" class="pill-link">Skills</a>
  </div>
</nav>

<script is:inline>
  const palette = ['#93565d', '#ffffff', '#000000'];
  let colorIndex = 0;
  
  function initNavbar() {
    const ps5Button = document.querySelector('.ps5-button');
    const powerIcon = document.querySelector('.power-icon');
    const pillLinks = document.querySelectorAll('.pill-link');
    const floatingPill = document.querySelector('.floating-pill');
    
    if (typeof gsap !== 'undefined') {
      // Entrance animation - only for the pill container
      gsap.from('.floating-pill', {
        y: -20,
        opacity: 0,
        duration: 0.6,
        ease: 'power2.out'
      });
      
      // Logo bounce
      gsap.from('.pill-logo', {
        scale: 0.5,
        duration: 0.3,
        delay: 0.4,
        ease: 'back.out(2)'
      });
      
      // Infinite color animation on PS5 button
      function animatePS5Button() {
        colorIndex = (colorIndex + 1) % palette.length;
        
        gsap.to(ps5Button, {
          borderColor: palette[colorIndex],
          boxShadow: `0 0 15px ${palette[colorIndex]}40, 0 0 30px ${palette[colorIndex]}20`,
          duration: 0.8,
          ease: 'sine.inOut',
          onComplete: animatePS5Button
        });
        
        gsap.to(powerIcon, {
          color: palette[colorIndex],
          duration: 0.8,
          ease: 'sine.inOut'
        });
      }
      
      animatePS5Button();
      
      // Hover effects for PS5 button
      ps5Button?.addEventListener('mouseenter', () => {
        gsap.killTweensOf(ps5Button);
        gsap.killTweensOf(powerIcon);
        
        gsap.to(ps5Button, {
          scale: 1.15,
          borderColor: '#fff',
          boxShadow: '0 0 25px rgba(255,255,255,0.5)',
          duration: 0.3,
          ease: 'power2.out'
        });
        
        gsap.to(powerIcon, {
          color: '#fff',
          duration: 0.3,
          ease: 'power2.out'
        });
      });
      
      ps5Button?.addEventListener('mouseleave', () => {
        animatePS5Button();
        
        gsap.to(ps5Button, {
          scale: 1,
          duration: 0.3,
          ease: 'power2.out'
        });
      });
      
      // Hover effects for pill links - simple CSS is enough
    }
    
    // Scroll effect - add scrolled class
    if (floatingPill) {
      window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
          floatingPill.classList.add('scrolled');
        } else {
          floatingPill.classList.remove('scrolled');
        }
      });
    }
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initNavbar);
  } else {
    initNavbar();
  }
</script>

<style>
  /* Floating Pill Navbar */
  .floating-pill {
    position: fixed;
    top: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    padding: 0.5rem 1.5rem;
    background: rgba(34, 34, 34, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 9999px;
    box-shadow: 
      0 4px 30px rgba(0, 0, 0, 0.3),
      0 0 20px rgba(147, 86, 93, 0.15);
    transition: all 0.3s ease;
  }

  .floating-pill:hover {
    background: rgba(34, 34, 34, 0.95);
    border-color: rgba(255, 255, 255, 0.2);
    box-shadow: 
      0 4px 40px rgba(0, 0, 0, 0.4),
      0 0 30px rgba(147, 86, 93, 0.25);
  }

  .pill-left,
  .pill-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .pill-left {
    justify-content: flex-end;
  }

  .pill-right {
    justify-content: flex-start;
  }

  .pill-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  /* PS5 Power Button Style */
  .ps5-button {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 2px solid #93565d;
    background: linear-gradient(145deg, #1a1a1a, #2d2d2d);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 
      0 0 12px rgba(147, 86, 93, 0.4),
      inset 0 1px 0 rgba(255,255,255,0.15);
  }

  .power-icon {
    width: 18px;
    height: 18px;
    color: #93565d;
    transition: color 0.3s ease;
  }

  .pill-link {
    color: #ffffff !important;
    text-decoration: none !important;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.4px;
    padding: 0.4rem 0.7rem;
    border-radius: 9999px;
    transition: all 0.25s ease;
    white-space: nowrap;
    background: transparent;
    display: inline-block;
    opacity: 1;
    visibility: visible;
  }

  .pill-link:hover {
    color: #ffffff !important;
    background: rgba(147, 86, 93, 0.3);
    text-shadow: 0 0 8px rgba(147, 86, 93, 0.5);
  }

  /* Scroll behavior - increase blur on scroll */
  .floating-pill.scrolled {
    background: rgba(34, 34, 34, 0.95);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    box-shadow: 
      0 4px 50px rgba(0, 0, 0, 0.5),
      0 0 40px rgba(147, 86, 93, 0.2);
  }

  @media (max-width: 900px) {
    .floating-pill {
      padding: 0.4rem 1rem;
      gap: 0.75rem;
    }

    .pill-left,
    .pill-right {
      gap: 0.25rem;
    }

    .pill-link {
      font-size: 0.75rem;
      padding: 0.3rem 0.5rem;
    }

    .ps5-button {
      width: 32px;
      height: 32px;
    }

    .power-icon {
      width: 15px;
      height: 15px;
    }
  }

  @media (max-width: 640px) {
    .pill-link {
      display: none;
    }
    
    .floating-pill {
      padding: 0.5rem;
      gap: 0.5rem;
    }
  }
</style>
