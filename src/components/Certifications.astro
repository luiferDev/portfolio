---
interface Certification {
	title: string;
	issuer: string;
	date: string;
	icon: string;
	verifyUrl?: string;
}

const certifications: Certification[] = [
	{
		title: 'Java Backend Developer',
		issuer: 'Alura Latam & Oracle ONE',
		date: 'Jun 2024',
		icon: 'mdi:language-java',
	},
	{
		title: 'Scrum Foundational Certification',
		issuer: 'Certiprof',
		date: 'Aug 2023',
		icon: 'mdi:scrumboard',
	},
	{
		title: 'Data Analyst',
		issuer: 'Correlation One',
		date: 'Oct 2022',
		icon: 'mdi:chart-box',
	},
];
---

<section class="max-w-6xl mx-auto" aria-label="certifications">
	<h2 class="section-title">Certifications</h2>
	<div class="certifications-grid">
		{certifications.map((cert, index) => (
			<article class="cert-card" data-index={index}>
				<div class="cert-card-inner">
					<div class="cert-icon">
						<iconify-icon icon={cert.icon}></iconify-icon>
					</div>
					<div class="cert-content">
						<h3 class="cert-title">{cert.title}</h3>
						<p class="cert-issuer">{cert.issuer}</p>
						<div class="cert-footer">
							<span class="cert-date">{cert.date}</span>
							{cert.verifyUrl && (
								<a href={cert.verifyUrl} target="_blank" rel="noopener noreferrer" class="cert-verify">
									<iconify-icon icon="mdi:open-in-new"></iconify-icon>
									Verify
								</a>
							)}
						</div>
					</div>
				</div>
				<div class="gradient-border"></div>
			</article>
		))}
	</div>
</section>

<script>
	import { gsap } from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';

	gsap.registerPlugin(ScrollTrigger);

	const cards = document.querySelectorAll('.cert-card');

	gsap.fromTo(
		cards,
		{ opacity: 0, y: 60 },
		{
			opacity: 1,
			y: 0,
			duration: 0.8,
			stagger: 0.15,
			ease: 'power3.out',
			scrollTrigger: {
				trigger: '.certifications-grid',
				start: 'top 80%',
				toggleActions: 'play none none reverse',
			},
		}
	);
</script>

<style>
	.section-title {
		font-family: 'Space Grotesk', sans-serif;
		font-size: clamp(2rem, 5vw, 2.5rem);
		font-weight: 700;
		color: #fff;
		margin: 0 0 2.5rem 0;
	}

	.certifications-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
	}

	@media (min-width: 768px) {
		.certifications-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (min-width: 1024px) {
		.certifications-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	.cert-card {
		position: relative;
		border-radius: 1rem;
		padding: 2px;
		background: linear-gradient(
			135deg,
			rgba(147, 86, 93, 0.3) 0%,
			rgba(255, 255, 255, 0.1) 50%,
			rgba(147, 86, 93, 0.3) 100%
		);
		transition: transform 0.3s ease, box-shadow 0.3s ease;
	}

	.cert-card:hover {
		transform: scale(1.02);
		box-shadow: 0 0 30px rgba(147, 86, 93, 0.4);
	}

	.cert-card-inner {
		background: rgba(255, 255, 255, 0.05);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: calc(1rem - 2px);
		padding: 1.5rem;
		height: 100%;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.cert-icon {
		width: 48px;
		height: 48px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: linear-gradient(135deg, #93565d, #b8767d);
		border-radius: 0.75rem;
	}

	.cert-icon iconify-icon {
		font-size: 1.75rem;
		color: #fff;
	}

	.cert-content {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		flex: 1;
	}

	.cert-title {
		font-family: 'Space Grotesk', sans-serif;
		font-size: 1.125rem;
		font-weight: 600;
		color: #fff;
		margin: 0;
		line-height: 1.3;
	}

	.cert-issuer {
		font-size: 0.875rem;
		color: rgba(255, 255, 255, 0.6);
		margin: 0;
	}

	.cert-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-top: auto;
		padding-top: 1rem;
		border-top: 1px solid rgba(255, 255, 255, 0.1);
	}

	.cert-date {
		font-size: 0.75rem;
		font-weight: 500;
		color: #93565d;
		background: rgba(147, 86, 93, 0.15);
		padding: 0.25rem 0.75rem;
		border-radius: 9999px;
	}

	.cert-verify {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		font-size: 0.75rem;
		color: rgba(255, 255, 255, 0.7);
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.cert-verify:hover {
		color: #fff;
	}

	.cert-verify iconify-icon {
		font-size: 0.875rem;
	}
</style>
