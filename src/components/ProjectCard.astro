---
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  description: string;
  image: string;
  technologies: string[];
  link?: string;
  github?: string;
  id: string;
  index: number;
}

const { title, description, image, technologies, link, github, id, index } = Astro.props;
---

<a
  href={`/projects/${id}`}
  data-gsap-project
  class="project-card group block bg-white/5 border border-white/10 backdrop-blur-md rounded-xl overflow-hidden hover:border-[#93565d]/50 transition-all duration-300 hover:shadow-lg hover:shadow-[#93565d]/10"
>
  <div class="aspect-video relative overflow-hidden">
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
  </div>
  <div class="p-5">
    <h3 class="text-lg font-bold mb-1 group-hover:text-[#93565d] transition-colors">
      {title}
    </h3>
    <p class="text-gray-400 text-sm line-clamp-2 mb-4">
      {description}
    </p>
    <div class="flex flex-wrap gap-2 mb-4">
      {technologies.slice(0, 4).map((tech) => (
        <span class="text-xs px-2 py-1 bg-[#93565d]/20 text-[#93565d] rounded-md">
          {tech}
        </span>
      ))}
      {technologies.length > 4 && (
        <span class="text-xs px-2 py-1 bg-white/5 text-gray-400 rounded-md">
          +{technologies.length - 4}
        </span>
      )}
    </div>
    <div class="flex items-center gap-4">
      {link && (
        <span class="flex items-center gap-1 text-sm text-gray-300 group-hover:text-white transition-colors">
          <Icon name="mdi:web" class="w-4 h-4" />
          <span>Live</span>
        </span>
      )}
      {github && (
        <span class="flex items-center gap-1 text-sm text-gray-300 group-hover:text-white transition-colors">
          <Icon name="mdi:github" class="w-4 h-4" />
          <span>Code</span>
        </span>
      )}
    </div>
  </div>
</a>
