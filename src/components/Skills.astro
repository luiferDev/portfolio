---
import { Icon } from 'astro-icon/components';

const allSkills = [
	// Frontend
	{ name: 'React', icon: 'mdi:react' },
	{ name: 'Astro', icon: 'simple-icons:astro' },
	{ name: 'Tailwind', icon: 'mdi:tailwind' },
	{ name: 'JavaScript', icon: 'mdi:language-javascript' },
	{ name: 'TypeScript', icon: 'mdi:language-typescript' },
	// Backend
	{ name: '.NET', icon: 'mdi:dot-net' },
	{ name: 'Node JS', icon: 'mdi:nodejs' },
	{ name: 'Java', icon: 'mdi:language-java' },
	{ name: 'Spring', icon: 'simple-icons:spring' },
	{ name: 'SQL', icon: 'mdi:database' },
	{ name: 'MongoDB', icon: 'simple-icons:mongodb' },
	{ name: 'Docker', icon: 'mdi:docker' },
	{ name: 'Kubernetes', icon: 'mdi:kubernetes' },
	// Testing
	{ name: 'Python', icon: 'mdi:language-python' },
	{ name: 'Selenium', icon: 'simple-icons:selenium' },
	{ name: 'Cypress', icon: 'simple-icons:cypress' },
	{ name: 'Playwright', icon: 'devicon-plain:playwright' },
	{ name: 'Postman', icon: 'devicon-plain:postman' },
	{ name: 'Insomnia', icon: 'devicon-plain:insomnia' },
	// Tools
	{ name: 'Git', icon: 'mdi:git' },
	{ name: 'GitHub', icon: 'mdi:github' },
	{ name: 'Jira', icon: 'mdi:jira' },
	{ name: 'Trello', icon: 'mdi:trello' },
];
---

<section id="skills" class="w-screen -mt-20 mb-8" style="transform: rotate(-10deg); z-index: 50;">
	<div class="w-full overflow-hidden py-6 bg-[#581a21]/60 backdrop-blur-xl border-y border-[#93565d]/30">
		<div class="flex gap-4 w-max" id="skills-band">
			{allSkills.map((skill) => (
				<div class="flex flex-col items-center justify-center min-w-[90px] py-4 px-5 bg-[#581a21]/80 backdrop-blur-sm border border-[#93565d]/40 rounded-xl transition-all duration-300 hover:bg-[#93565d]/80 hover:border-[#93565d]/60 hover:scale-105" style="box-shadow: 0 4px 20px rgba(147, 86, 93, 0.2);">
					<Icon name={skill.icon} class="w-7 h-7 text-white mb-1" />
					<span class="text-xs text-gray-100 font-medium">{skill.name}</span>
				</div>
			))}
			{allSkills.map((skill) => (
				<div class="flex flex-col items-center justify-center min-w-[90px] py-4 px-5 bg-[#581a21]/80 backdrop-blur-sm border border-[#93565d]/40 rounded-xl transition-all duration-300 hover:bg-[#93565d]/80 hover:border-[#93565d]/60 hover:scale-105" style="box-shadow: 0 4px 20px rgba(147, 86, 93, 0.2);">
					<Icon name={skill.icon} class="w-7 h-7 text-white mb-1" />
					<span class="text-xs text-gray-100 font-medium">{skill.name}</span>
				</div>
			))}
		</div>
	</div>
</section>

<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		const band = document.getElementById('skills-band');
		
		if (band && typeof gsap !== 'undefined') {
			const cardWidth = 100;
			const numSkills = 24;
			const singleSetWidth = cardWidth * numSkills;
			
			const anim = gsap.to(band, {
				x: -singleSetWidth,
				duration: 30,
				repeat: -1,
				ease: 'none',
				modifiers: {
					x: gsap.utils.unitize(x => parseFloat(x) % singleSetWidth)
				}
			});
			
			band.parentElement.addEventListener('mouseenter', () => anim.pause());
			band.parentElement.addEventListener('mouseleave', () => anim.play());
		}
	});
</script>

<style>
	@media (max-width: 768px) {
		section#skills {
			margin-top: 0 !important;
			transform: rotate(0deg) !important;
		}
	}
</style>
