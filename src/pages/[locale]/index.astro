---
import Layout from '../../app/layout/Layout.astro';
import LuiferDev from '../../entities/profile/LuiferDev.astro';
import AboutSection from '../../widgets/about/AboutSection.astro';
import ExperienceSection from '../../widgets/experience/ExperienceSection.astro';
import EducationSection from '../../widgets/education/EducationSection.astro';
import ProjectsSection from '../../widgets/projects/ProjectsSection.astro';
import CertificationsSection from '../../widgets/certifications/CertificationsSection.astro';
import SkillsSection from '../../widgets/skills/SkillsSection.astro';
import Footer from '../../widgets/footer/Footer.astro';

export function getStaticPaths() {
  return [
    { params: { locale: 'en' } },
    { params: { locale: 'fr' } },
  ];
}

const { locale } = Astro.params;
---

<Layout locale={locale}>
	<div id="hero"><LuiferDev locale={locale} /></div>
	<div id="skills"><SkillsSection locale={locale} /></div>
	<div id="about"><AboutSection locale={locale} /></div>
	<div id="experience"><ExperienceSection locale={locale} /></div>
	<div id="education"><EducationSection locale={locale} /></div>
	<div id="projects"><ProjectsSection locale={locale} /></div>
	<div id="certifications"><CertificationsSection locale={locale} /></div>
	<Footer locale={locale} />
</Layout>

<script is:inline>
  function initScrollAnimations() {
    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') {
      setTimeout(initScrollAnimations, 100);
      return;
    }
    
    gsap.registerPlugin(ScrollTrigger);
    
    const sections = document.querySelectorAll('#about, #experience, #education, #projects, #certifications, #skills');
    
    sections.forEach((section, index) => {
      gsap.from(section, {
        scrollTrigger: {
          trigger: section,
          start: 'top 85%',
          toggleActions: 'play none none reverse'
        },
        y: 25,
        opacity: 0,
        duration: 0.6,
        ease: 'power2.out',
        delay: index * 0.05
      });
    });
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initScrollAnimations);
  } else {
    initScrollAnimations();
  }
</script>
