# Sentry Error Tracking
# Get your DSN from: https://docs.sentry.io/product/sentry-basics/dsn-explainer/
PUBLIC_SENTRY_DSN=

# Sentry Organization (slug from your Sentry dashboard)
SENTRY_ORG=

# Sentry Project Name
SENTRY_PROJECT=

# Sentry Auth Token (for source map uploads)
# Generate at: https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=
